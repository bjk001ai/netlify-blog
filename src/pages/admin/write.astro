---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { db, posts, categories } from '../../db';

let errorMessage = '';
let successMessage = '';

// Load all categories for select input dropdown
let categoriesList = [];
try {
  categoriesList = await db.query.categories.findMany();
} catch (error) {
  console.error("Failed to load categories in admin write:", error);
}

// Handle Form POST Submission
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const title = data.get('title')?.toString().trim();
    const slug = data.get('slug')?.toString().trim().toLowerCase();
    const description = data.get('description')?.toString().trim();
    const content = data.get('content')?.toString().trim();
    const categoryIdVal = data.get('categoryId')?.toString();
    const passcode = data.get('passcode')?.toString();

    // Passcode validation
    const expectedPasscode = (typeof import.meta !== 'undefined' && import.meta.env?.ADMIN_PASSCODE) || process.env.ADMIN_PASSCODE || 'secret123';
    
    if (passcode !== expectedPasscode) {
      errorMessage = '어드민 비밀번호가 유효하지 않습니다. 권한이 거부되었습니다.';
    } else if (!title || !slug || !description || !content || !categoryIdVal) {
      errorMessage = '모든 입력 필수값을 채워주시기 바랍니다.';
    } else {
      const categoryId = parseInt(categoryIdVal, 10);
      
      await db.insert(posts).values({
        title,
        slug,
        description,
        content,
        categoryId,
      });

      successMessage = '새로운 블로그 글이 성공적으로 데이터베이스에 등록되었습니다!';
      return Astro.redirect(`/blog/${slug}`);
    }
  } catch (error) {
    console.error("Failed to save new post:", error);
    errorMessage = '블로그 게시글 저장 도중 에러가 발생했습니다. 슬러그 중복 여부를 확인하세요.';
  }
}
---

<BaseLayout title="Write Post" description="Compose and publish technical articles instantly into Postgres database.">
  <div class="max-w-3xl mx-auto space-y-12">
    <!-- Header -->
    <div class="space-y-4">
      <h1 class="text-4xl font-extrabold font-display tracking-tight text-white sm:text-5xl">
        Compose <span class="text-gradient-cyan">Article</span>
      </h1>
      <p class="text-gray-400 text-lg leading-relaxed">
        데이터베이스에 실시간으로 보관될 기술 포스트 및 에세이를 작성합니다.
      </p>
    </div>

    <!-- Alert banners -->
    {errorMessage && (
      <div class="p-4 rounded-xl border border-red-500/30 bg-red-500/10 text-red-300 text-sm">
        {errorMessage}
      </div>
    )}
    {successMessage && (
      <div class="p-4 rounded-xl border border-green-500/30 bg-green-500/10 text-green-300 text-sm">
        {successMessage}
      </div>
    )}

    <!-- Form -->
    <section class="glass-panel rounded-2xl p-6 md:p-8 relative">
      <form method="POST" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Title -->
          <div class="space-y-2">
            <label for="title" class="text-xs font-semibold uppercase tracking-wider text-gray-400">Post Title</label>
            <input 
              type="text" 
              id="title" 
              name="title" 
              required
              placeholder="Astro 5.0 deep dive"
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500/50 transition-all duration-200"
            />
          </div>

          <!-- Slug -->
          <div class="space-y-2">
            <label for="slug" class="text-xs font-semibold uppercase tracking-wider text-gray-400">Slug (URL Path)</label>
            <input 
              type="text" 
              id="slug" 
              name="slug" 
              required
              placeholder="astro-5-deep-dive"
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500/50 transition-all duration-200"
            />
          </div>

          <!-- Category -->
          <div class="space-y-2">
            <label for="categoryId" class="text-xs font-semibold uppercase tracking-wider text-gray-400">Category</label>
            <select 
              id="categoryId" 
              name="categoryId" 
              required
              class="w-full px-4 py-3 rounded-xl bg-[#0d121e] border border-white/10 text-gray-300 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500/50 transition-all duration-200"
            >
              <option value="" disabled selected>Select category...</option>
              {categoriesList.map((category) => (
                <option value={category.id}>{category.name}</option>
              ))}
            </select>
          </div>

          <!-- Passcode -->
          <div class="space-y-2">
            <label for="passcode" class="text-xs font-semibold uppercase tracking-wider text-gray-400">Admin Passcode</label>
            <input 
              type="password" 
              id="passcode" 
              name="passcode" 
              required
              placeholder="secret123"
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500/50 transition-all duration-200"
            />
          </div>
        </div>

        <!-- Description -->
        <div class="space-y-2">
          <label for="description" class="text-xs font-semibold uppercase tracking-wider text-gray-400">Short Summary Description</label>
          <input 
            type="text" 
            id="description" 
            name="description" 
            required
            placeholder="Write a catchy 2-3 sentence overview of this article..."
            class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500/50 transition-all duration-200"
          />
        </div>

        <!-- Content -->
        <div class="space-y-2">
          <label for="content" class="text-xs font-semibold uppercase tracking-wider text-gray-400">Content (Markdown Supported)</label>
          <textarea 
            id="content" 
            name="content" 
            required
            rows="12"
            placeholder="## Section Title&#10;Write the body content here using markdown..."
            class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500/50 transition-all duration-200 resize-y font-mono text-sm leading-relaxed"
          ></textarea>
        </div>

        <!-- Submit -->
        <button 
          type="submit"
          class="w-full sm:w-auto px-8 py-3 rounded-xl bg-gradient-to-r from-cyan-500 to-indigo-500 hover:from-cyan-600 hover:to-indigo-600 text-white font-semibold text-sm shadow-md hover:-translate-y-0.5 transition-all duration-300 cursor-pointer"
        >
          Publish Article
        </button>
      </form>
    </section>
  </div>
</BaseLayout>
