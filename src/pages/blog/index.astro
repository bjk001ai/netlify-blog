---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { db } from '../../db';

const categorySlug = Astro.url.searchParams.get('category');

let posts = [];
let categoriesList = [];

try {
  categoriesList = await db.query.categories.findMany();
  
  const selectedCategory = categoriesList.find(c => c.slug === categorySlug);
  
  if (selectedCategory) {
    posts = await db.query.posts.findMany({
      where: (posts, { eq }) => eq(posts.categoryId, selectedCategory.id),
      orderBy: (posts, { desc }) => [desc(posts.createdAt)],
      with: {
        category: true,
      },
    });
  } else {
    posts = await db.query.posts.findMany({
      orderBy: (posts, { desc }) => [desc(posts.createdAt)],
      with: {
        category: true,
      },
    });
  }
} catch (error) {
  console.error("Failed to load blog posts:", error);
}
---

<BaseLayout title="Blog Archive" description="A complete collection of all articles, technical analysis, and posts.">
  <div class="space-y-12">
    <!-- Header -->
    <div class="space-y-4 max-w-2xl">
      <h1 class="text-4xl font-extrabold font-display tracking-tight text-white sm:text-5xl">
        Writing & <span class="text-gradient">Resources</span>
      </h1>
      <p class="text-gray-400 text-lg leading-relaxed">
        프로젝트 트러블슈팅, 신기술 아키텍처에 관한 기술 분석 글을 한눈에 모아보세요.
      </p>
    </div>

    <!-- Category Filter Bar -->
    <div class="flex flex-wrap gap-2 border-b border-white/5 pb-6">
      <a 
        href="/blog" 
        class={`px-4 py-1.5 rounded-full text-xs font-semibold uppercase border transition-all duration-200 ${
          !categorySlug 
            ? 'border-purple-500 bg-purple-500/20 text-white shadow-lg shadow-purple-500/10' 
            : 'border-white/10 text-gray-400 hover:border-white/20 hover:text-white bg-white/5'
        }`}
      >
        All Articles
      </a>
      {categoriesList.map((category) => {
        const isActive = categorySlug === category.slug;
        return (
          <a 
            href={`/blog?category=${category.slug}`} 
            class={`px-4 py-1.5 rounded-full text-xs font-semibold uppercase border transition-all duration-200 ${
              isActive 
                ? 'border-purple-500 bg-purple-500/20 text-white shadow-lg shadow-purple-500/10' 
                : 'border-white/10 text-gray-400 hover:border-white/20 hover:text-white bg-white/5'
            }`}
          >
            {category.name}
          </a>
        );
      })}
    </div>

    <!-- Grid -->
    {posts.length === 0 ? (
      <div class="glass-panel rounded-2xl p-16 text-center text-gray-500 space-y-4">
        <p class="text-lg">No publications found.</p>
        <p class="text-sm text-gray-600">Please make sure to run the seed script to populate posts database.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard
            title={post.title}
            slug={post.slug}
            description={post.description}
            date={post.createdAt}
            category={post.category?.name}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
